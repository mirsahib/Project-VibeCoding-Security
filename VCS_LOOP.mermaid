graph TD
    classDef input fill:#e1f5fe,stroke:#0277bd,stroke-width:2px,color:#000;
    classDef process fill:#fff,stroke:#333,stroke-width:2px,color:#000;
    classDef sensor fill:#ffebee,stroke:#c62828,stroke-width:2px,color:#000;
    classDef hub fill:#e8f5e9,stroke:#2e7d32,stroke-width:4px,color:#000,font-weight:bold;

    Prompt["CWEID Prompt & llmseceval Prompt"]:::input
    TestCases("Standardized Test Cases Generated by openai/gpt-5.4-nano"):::hub
    Model[["AI Model Agent (e.g., llama-3.3-70b-instruct,/glm-4.7-flash",qwen3.5-9b")"]]:::process
    GenCode["Generated Code Artifact (main.c)"]:::process
    Snyk[["Snyk Code SAST Sensor (CWE Detection)"]]:::sensor
    Docs["Final Verified App & Report (docs/)"]:::process

    Prompt -->|1. Intent| Model
    Model -->|2. Generate| GenCode
    GenCode -->|3. Analyze| Snyk
    GenCode -->|4. Execute| TestCases
    Snyk -->|5. Vulnerability Report JSON| Model
    TestCases -.->|6. Functional Pass/Fail| Model
    TestCases -->|7. Verified Success| Docs

    linkStyle 4 stroke-width:3px,stroke:#c62828,stroke-dasharray:5 5;
    linkStyle 5 stroke-width:3px,stroke:#2e7d32,stroke-dasharray:5 5;

    subgraph Iteration_Phase ["Iterative Mitigation Loop"]
        direction RL
        Snyk
        Model
    end